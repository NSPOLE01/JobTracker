# --- Local development only ---
# Use DATABASE_URL when running locally (not needed on AWS, where DB_SECRET_ARN is used instead)
DATABASE_URL=postgresql://username:password@localhost:5432/jobtracker

# --- AWS production ---
# ARN of the Secrets Manager secret containing RDS credentials (replaces DATABASE_URL on AWS)
# DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:jobtracker/rds-xxxx
AWS_REGION=us-east-1

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Optional — enables Claude-powered email parsing (much more accurate)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
