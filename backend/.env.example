# Get this from Supabase: Project Settings → Database → Connection string → URI
# Use the "Session mode" pooler URL (port 5432) — append ?sslmode=require
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Optional — enables Claude-powered email parsing (much more accurate)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
